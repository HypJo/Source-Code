    def get_vaults(self): ensure_dirs(); return sorted([p for p in VAULT_ROOT.iterdir() if p.is_dir()], reverse=True)
    def vault_meta(self,v):
        try: return json.loads((v/'metadata.json').read_text(encoding='utf-8'))
        except Exception: return {'items':[]}
    def open_vault(self):
        ensure_dirs()
        try: os.startfile(str(VAULT_ROOT)) if IS_WINDOWS else subprocess.Popen(['open' if IS_MAC else 'xdg-open', str(VAULT_ROOT)])
        except Exception as exc: messagebox.showerror(APP_NAME,str(exc))
    def restore_latest(self):
        v=self.get_vaults()
        if not v: messagebox.showinfo(APP_NAME,'No vault backups found.'); return
        self.restore_path(v[0])
    def restore_selected(self):
        sel=self.vault_tree.selection() if hasattr(self,'vault_tree') else []
        if not sel: messagebox.showinfo(APP_NAME,'Select a vault first.'); return
        self.restore_path(Path(self.vault_tree.item(sel[0],'values')[3]))
    def restore_path(self,vault):
        if not messagebox.askyesno(APP_NAME,f'Restore missing files from this vault?\nExisting files will not be overwritten.\n\n{vault}'): return
        ok,fail,notes=restore_vault(Path(vault)); history({'action':'restore_vault','status':'ok' if fail==0 else 'partial','vault':str(vault),'restored':ok,'failed':fail}); self.log_msg(f'Vault restore complete: {ok} restored, {fail} failed/skipped.',GREEN if fail==0 else ORANGE)
        if notes: messagebox.showinfo(APP_NAME,'\n'.join(notes[:20]))

