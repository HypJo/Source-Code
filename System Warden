    def refresh_programs(self):
        self.log_msg('Scanning installed programs...',GOLD)
        def work():
            try: progs=discover_programs(); self.after(0,lambda:self.finish_refresh(progs))
            except Exception as exc: self.after(0,lambda:self.log_msg(f'Program scan failed: {exc}',RED))
        threading.Thread(target=work,daemon=True).start()
    def finish_refresh(self,progs):
        self.programs=progs; self.log_msg(f'Found {len(progs)} installed programs.',GREEN)
        if self.current_page=='Programs': self.populate_programs()
        if self.current_page=='Dashboard': self.show_dashboard()

