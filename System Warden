        bar=self.card(self.content,fill='x'); r=tk.Frame(bar,bg=PANEL); r.pack(fill='x',padx=14,pady=14); self.btn(r,'Refresh',self.show_history).pack(side='left',padx=(0,8)); self.btn(r,'Export Report',self.export_report).pack(side='left',padx=8)
