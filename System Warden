    def empty_queue(self,msg):
        for w in self.items_frame.winfo_children(): w.destroy()
        self.queue=[]; self.queue_widgets={}; self.queue_lbl.configure(text='0 items')
        tk.Label(self.items_frame,text=msg,bg=BG_2,fg=TEXT_DIM,font=FONT_UI,justify='center').pack(expand=True,fill='both',padx=18,pady=32)
    def render_queue(self,paths,msg='Queued items.'):
        for w in self.items_frame.winfo_children(): w.destroy()
        self.queue=[]; self.queue_widgets={}
        if not paths: self.empty_queue('No cleanup items found.'); self.log_msg('No items found.',ORANGE); return
        total=0
        for p in paths:
            if not Path(p).exists(): continue
            sz=path_size(p); total+=sz; self.add_row(p,sz)
        self.refresh_queue_label(); self.log_msg(msg,GREEN)
    def add_row(self,path,sz=None):
        if not hasattr(self,'items_frame'): return
        if not hasattr(self,'queue_widgets'): self.queue_widgets={}
        sz=path_size(path) if sz is None else sz
        var=tk.BooleanVar(value=True)
        row=tk.Frame(self.items_frame,bg=BG_2,highlightbackground=BORDER,highlightthickness=1)
        row.pack(fill='x',padx=8,pady=5)
        cb=tk.Checkbutton(row,variable=var,bg=BG_2,activebackground=BG_2,fg=TEXT,activeforeground=TEXT,selectcolor=GREEN,font=FONT_SMALL,command=self.refresh_queue_label)
        cb.pack(side='left',padx=(8,4),pady=8)
        icon='Folder' if Path(path).is_dir() else 'File'
        tk.Label(row,text=f"{icon}  {path}\n{format_size(sz)}",bg=BG_2,fg=TEXT,font=FONT_SMALL,justify='left',anchor='w').pack(side='left',fill='x',expand=True,pady=7)
        self.queue.append((path,var,sz))
        self.queue_widgets[path]=cb
        self.refresh_queue_label()
    def refresh_queue_label(self):
        if not hasattr(self,'queue_lbl') or not hasattr(self,'queue'): return
        total=sum(sz for _p,_v,sz in self.queue)
        selected=sum(1 for _p,v,_s in self.queue if v.get())
        self.queue_lbl.configure(text=f"{selected}/{len(self.queue)} selected • {format_size(total)}" if self.queue else '0 items')
    def toggle_all(self,state):
        if not hasattr(self,'queue') or not self.queue:
            self.log_msg('No cleanup items are currently queued.', ORANGE)
            return
        for _p,v,_s in self.queue:
            v.set(bool(state))
        self.refresh_queue_label()
        self.update_idletasks()
        self.log_msg(('Selected all' if state else 'Cleared checks') + f' ({len(self.queue)} item(s)).', CYAN)
