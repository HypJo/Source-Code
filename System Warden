@dataclass
class Program:
    name: str
    version: str = ""
    location: str = ""
    uninstall: str = ""
    source: str = ""


def resource_path(name: str) -> Path:
    base = Path(getattr(sys, "_MEIPASS", Path(__file__).resolve().parent))
    return base / name


def ensure_dirs() -> None:
    APP_DIR.mkdir(parents=True, exist_ok=True)
    VAULT_ROOT.mkdir(parents=True, exist_ok=True)


def load_settings() -> dict:
    ensure_dirs()
    defaults = {"create_restore_point": IS_WINDOWS, "backup_vault": True, "deep_scan_limit": 1500}
    if SETTINGS_FILE.exists():
        try:
            defaults.update(json.loads(SETTINGS_FILE.read_text(encoding="utf-8")))
        except Exception:
            pass
    return defaults


def save_settings(data: dict) -> None:
    ensure_dirs()
    SETTINGS_FILE.write_text(json.dumps(data, indent=2), encoding="utf-8")


def append_history(entry: dict) -> None:
    ensure_dirs()
    entry = {"time": datetime.now().isoformat(timespec="seconds"), **entry}
    with HISTORY_FILE.open("a", encoding="utf-8") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")


def read_history(limit: int = 300) -> list[dict]:
    if not HISTORY_FILE.exists():
        return []
    out = []
    with HISTORY_FILE.open("r", encoding="utf-8", errors="ignore") as f:
        for line in f:
            try:
                out.append(json.loads(line))
            except Exception:
                pass
    return out[-limit:][::-1]


def format_size(size: int | float) -> str:
    try:
        size = float(size)
        for unit in ("B", "KB", "MB", "GB", "TB"):
            if size < 1024 or unit == "TB":
                return f"{size:.1f} {unit}" if unit != "B" else f"{int(size)} B"
            size /= 1024
    except Exception:
        return "0 B"


def path_size(path: str | Path) -> int:
    p = Path(path)
    try:
        if p.is_file() or p.is_symlink():
            return p.stat().st_size
        total = 0
        for root, _dirs, files in os.walk(p):
            for f in files:
                try:
                    total += (Path(root) / f).stat().st_size
                except OSError:
                    pass
        return total
    except Exception:
        return 0


def discover_programs() -> list[Program]:
    if IS_WINDOWS:
        return discover_windows()
    if IS_MAC:
        return discover_mac()
    return discover_linux()


def discover_windows() -> list[Program]:
    import winreg
    found = {}
    roots = [
        (winreg.HKEY_LOCAL_MACHINE, r"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"),
        (winreg.HKEY_LOCAL_MACHINE, r"SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall"),
        (winreg.HKEY_CURRENT_USER, r"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"),
    ]
    for hive, key_path in roots:
        try:
            key = winreg.OpenKey(hive, key_path)
        except OSError:
            continue
        try:
            count = winreg.QueryInfoKey(key)[0]
            for i in range(count):
                try:
                    sub = winreg.EnumKey(key, i)
                    sk = winreg.OpenKey(key, sub)
                except OSError:
                    continue
                def val(name: str) -> str:
                    try:
                        return str(winreg.QueryValueEx(sk, name)[0])
                    except OSError:
                        return ""
                name = val("DisplayName").strip()
                if not name:
                    continue
                found[name.lower()] = Program(name, val("DisplayVersion"), val("InstallLocation"), val("UninstallString"), "registry")
        finally:
            try:
                winreg.CloseKey(key)
            except Exception:
                pass
    return sorted(found.values(), key=lambda p: p.name.lower())


def discover_mac() -> list[Program]:
    apps = []
    for base in (Path("/Applications"), Path.home() / "Applications"):
        if not base.exists():
            continue
        for item in base.iterdir():
            if item.suffix == ".app":
                apps.append(Program(item.stem, location=str(item), source="app_bundle"))
    return sorted(apps, key=lambda p: p.name.lower())


def discover_linux() -> list[Program]:
    apps = {}
    for d in (Path("/usr/share/applications"), Path("/usr/local/share/applications"), Path.home()/".local/share/applications"):
        if not d.exists():
            continue
        for file in d.glob("*.desktop"):
            name, loc = file.stem, str(file)
            try:
                for line in file.read_text(errors="ignore").splitlines():
                    if line.startswith("Name="):
                        name = line.split("=",1)[1].strip()
                    elif line.startswith("Exec="):
                        loc = line.split("=",1)[1].strip()
            except Exception:
                pass
            apps[name.lower()] = Program(name, location=loc, source="desktop")
    return sorted(apps.values(), key=lambda p: p.name.lower())


def scan_associated_paths(program: Program, deep: bool=False, limit: int=1500) -> list[str]:
    paths: list[str] = []
    loc = program.location.strip().strip('"')
    if loc and Path(loc).exists():
        paths.append(str(Path(loc)))
    tokens = [t for t in program.name.replace("("," ").replace(")"," ").replace("-"," ").split() if len(t) > 2]
    needles = {program.name.lower()}
    needles.update(t.lower() for t in tokens[:3])
    roots: list[Path] = []
    if IS_WINDOWS:
        for env in ("PROGRAMFILES", "PROGRAMFILES(X86)", "PROGRAMDATA", "LOCALAPPDATA", "APPDATA"):
            v = os.environ.get(env)
            if v:
                roots.append(Path(v))
    else:
        roots += [Path.home()/".config", Path.home()/".local/share"]
        if IS_MAC:
            roots.append(Path.home()/"Library/Application Support")
    seen = set(map(str, paths))
    for root in roots:
        if not root.exists():
            continue
        try:
            iterator = root.rglob("*") if deep else root.iterdir()
            checked = 0
            for entry in iterator:
                checked += 1
                if checked > limit and deep:
                    break
                low = entry.name.lower()
                if any(n and n in low for n in needles):
                    s = str(entry)
                    if s not in seen:
                        seen.add(s); paths.append(s)
        except Exception:
            continue
    return paths


def get_temp_items() -> list[str]:
    roots = [Path(tempfile.gettempdir())]
    if IS_WINDOWS:
        for env in ("TEMP", "TMP"):
            v = os.environ.get(env)
            if v:
                roots.append(Path(v))
    out = []
    seen = set()
    for root in roots:
        if not root.exists():
            continue
        try:
            for entry in root.iterdir():
                s = str(entry)
                if s not in seen:
                    seen.add(s); out.append(s)
        except Exception:
            pass
    return out


def create_restore_point(description: str) -> tuple[bool, str]:
    if not IS_WINDOWS:
        return False, "Restore points are Windows-only."
    cmd = ["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", f"Checkpoint-Computer -Description '{description}' -RestorePointType 'MODIFY_SETTINGS'"]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=90)
        if result.returncode == 0:
            return True, "Windows restore point created."
        msg = (result.stderr or result.stdout or "Unknown PowerShell error").strip()
        return False, msg
    except Exception as exc:
        return False, str(exc)


def backup_paths(paths: list[str]) -> tuple[Path | None, str]:
    ensure_dirs()
    stamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S")
    vault = VAULT_ROOT / stamp
    vault.mkdir(parents=True, exist_ok=True)
    meta = {"created": datetime.now().isoformat(timespec="seconds"), "items": []}
    for src in paths:
        p = Path(src)
        if not p.exists():
            continue
        safe = p.drive.replace(":", "") if p.drive else "root"
        rel_parts = [part for part in p.parts if part not in (p.anchor, p.drive, "\\", "/")]
        dest = vault / "files" / safe / Path(*rel_parts)
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            if p.is_dir() and not p.is_symlink():
                shutil.copytree(p, dest, dirs_exist_ok=True)
            else:
                shutil.copy2(p, dest)
            meta["items"].append({"source": str(p), "backup": str(dest), "size": path_size(p)})
        except Exception as exc:
            meta["items"].append({"source": str(p), "error": str(exc), "size": path_size(p)})
    (vault / "metadata.json").write_text(json.dumps(meta, indent=2), encoding="utf-8")
    return vault, f"Backed up {len([i for i in meta['items'] if 'backup' in i])} item(s)."


def delete_path(path: str) -> tuple[bool, str]:
    p = Path(path)
    try:
        if p.is_dir() and not p.is_symlink():
            shutil.rmtree(p)
        else:
            p.unlink()
        return True, f"Removed: {p}"
    except Exception as exc:
        return False, f"Failed: {p} — {exc}"


def restore_vault(vault: Path) -> tuple[int, int, list[str]]:
    meta_file = vault / "metadata.json"
    if not meta_file.exists():
        return 0, 0, ["metadata.json not found"]
    meta = json.loads(meta_file.read_text(encoding="utf-8"))
    ok = fail = 0; notes=[]
    for item in meta.get("items", []):
        src = Path(item.get("source", "")); bak = Path(item.get("backup", ""))
        if not bak.exists():
            fail += 1; notes.append(f"Missing backup: {bak}"); continue
        if src.exists():
            notes.append(f"Skipped existing: {src}"); continue
        try:
            src.parent.mkdir(parents=True, exist_ok=True)
            if bak.is_dir():
                shutil.copytree(bak, src)
            else:
                shutil.copy2(bak, src)
            ok += 1
        except Exception as exc:
            fail += 1; notes.append(f"Failed {src}: {exc}")
    return ok, fail, notes


