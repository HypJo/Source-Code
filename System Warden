@dataclass(frozen=True)
class Program:
    name: str
    version: str = ""
    publisher: str = ""
    location: str = ""
    uninstall: str = ""
    source: str = ""
    def row(self) -> str:
        return self.name + (f"  v{self.version}" if self.version else "") + (f"  • {self.publisher}" if self.publisher else "")


def ensure_dirs() -> None:
    APP_DIR.mkdir(parents=True, exist_ok=True)
    VAULT_ROOT.mkdir(parents=True, exist_ok=True)


def resource_path(name: str) -> Path:
    return Path(getattr(sys, "_MEIPASS", Path(__file__).resolve().parent)) / name


def load_settings() -> dict:
    ensure_dirs()
    data = {"restore_point": IS_WINDOWS, "backup_vault": True, "deep_limit": 3000}
    if SETTINGS_FILE.exists():
        try: data.update(json.loads(SETTINGS_FILE.read_text(encoding="utf-8")))
        except Exception: pass
    return data


def save_settings(data: dict) -> None:
    ensure_dirs(); SETTINGS_FILE.write_text(json.dumps(data, indent=2), encoding="utf-8")


def history(entry: dict) -> None:
    ensure_dirs()
    entry = {"time": datetime.now().isoformat(timespec="seconds"), **entry}
    with HISTORY_FILE.open("a", encoding="utf-8") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")


def read_history(limit: int = 500) -> list[dict]:
    if not HISTORY_FILE.exists(): return []
    rows = []
    for line in HISTORY_FILE.read_text(encoding="utf-8", errors="ignore").splitlines():
        try: rows.append(json.loads(line))
        except Exception: pass
    return rows[-limit:][::-1]


def format_size(n: int | float) -> str:
    try:
        n = float(n)
        for unit in ("B", "KB", "MB", "GB", "TB"):
            if n < 1024 or unit == "TB":
                return f"{int(n)} B" if unit == "B" else f"{n:.1f} {unit}"
            n /= 1024
    except Exception:
        return "0 B"


def path_size(path: str | Path) -> int:
    p = Path(path)
    try:
        if p.is_file() or p.is_symlink(): return p.stat().st_size
        total = 0
        for root, _dirs, files in os.walk(p):
            for f in files:
                try: total += (Path(root) / f).stat().st_size
                except OSError: pass
        return total
    except Exception:
        return 0


def normalize_path(raw: str) -> str:
    raw = os.path.expandvars((raw or "").strip().strip('"'))
    raw = re.sub(r",\s*\d+$", "", raw).replace("%1", "").strip().strip('"')
    p = Path(raw)
    if p.exists(): return str(p)
    return ""


def discover_programs() -> list[Program]:
    if IS_WINDOWS: return discover_windows()
    if IS_MAC: return discover_mac()
    return discover_linux()


def discover_windows() -> list[Program]:
    import winreg
    found: dict[str, Program] = {}
    roots = [
        (winreg.HKEY_LOCAL_MACHINE, r"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"),
        (winreg.HKEY_LOCAL_MACHINE, r"SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall"),
        (winreg.HKEY_CURRENT_USER, r"SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall"),
    ]
    for hive, reg_path in roots:
        try: key = winreg.OpenKey(hive, reg_path)
        except OSError: continue
        try:
            for i in range(winreg.QueryInfoKey(key)[0]):
                try:
                    sub = winreg.OpenKey(key, winreg.EnumKey(key, i))
                except OSError: continue
                def val(name: str) -> str:
                    try: return str(winreg.QueryValueEx(sub, name)[0]).strip()
                    except OSError: return ""
                name = val("DisplayName")
                if not name: continue
                if val("SystemComponent") == "1" or val("ReleaseType").lower() == "update": continue
                loc = val("InstallLocation")
                if not loc:
                    icon = normalize_path(val("DisplayIcon"))
                    if icon: loc = str(Path(icon).parent if Path(icon).is_file() else Path(icon))
                found[name.lower()] = Program(name, val("DisplayVersion"), val("Publisher"), loc, val("UninstallString"), "Windows Registry")
        finally:
            try: winreg.CloseKey(key)
            except Exception: pass
    return sorted(found.values(), key=lambda p: p.name.lower())


def discover_mac() -> list[Program]:
    apps=[]
    for base in (Path('/Applications'), Path.home()/'Applications'):
        if base.exists():
            for app in base.glob('*.app'): apps.append(Program(app.stem, location=str(app), source='Application Bundle'))
    return sorted(apps, key=lambda p: p.name.lower())


def discover_linux() -> list[Program]:
    apps={}
    for d in (Path('/usr/share/applications'), Path('/usr/local/share/applications'), Path.home()/'.local/share/applications'):
        if not d.exists(): continue
        for file in d.glob('*.desktop'):
            name=file.stem; loc=str(file)
            try:
                for line in file.read_text(errors='ignore').splitlines():
                    if line.startswith('Name='): name=line.split('=',1)[1].strip() or name
                    if line.startswith('Exec='): loc=line.split('=',1)[1].strip()
            except Exception: pass
            apps[name.lower()]=Program(name, location=loc, source='Desktop Entry')
    return sorted(apps.values(), key=lambda p: p.name.lower())


def needles(program: Program | str) -> list[str]:
    text = program if isinstance(program, str) else f"{program.name} {program.publisher}"
    parts = re.findall(r"[a-z0-9]{3,}", text.lower())
    blocked = {"the", "and", "for", "with", "app", "application", "setup", "installer", "update", "microsoft", "windows"}
    out=[]
    for p in parts:
        if p not in blocked and p not in out: out.append(p)
    return out[:4]


def scan_associated_paths(program: Program | str, deep: bool=False, limit: int=3000) -> list[str]:
    out=[]; seen=set()
    if isinstance(program, Program) and program.location:
        loc = normalize_path(program.location)
        if loc: out.append(loc); seen.add(loc)
    roots=[]
    if IS_WINDOWS:
        for env in ("PROGRAMFILES", "PROGRAMFILES(X86)", "PROGRAMDATA", "LOCALAPPDATA", "APPDATA"):
            v=os.environ.get(env)
            if v: roots.append(Path(v))
    else:
        roots=[Path.home()/'.config', Path.home()/'.local/share']
        if IS_MAC: roots.append(Path.home()/'Library/Application Support')
    ns = needles(program)
    for root in roots:
        if not root.exists(): continue
        try:
            iterator = root.rglob('*') if deep else root.iterdir()
            checked=0
            for e in iterator:
                checked += 1
                if deep and checked > limit: break
                name=e.name.lower()
                if any(n in name for n in ns):
                    s=str(e)
                    if s not in seen: seen.add(s); out.append(s)
        except Exception: continue
    return out


def temp_items() -> list[str]:
    roots=[Path(tempfile.gettempdir())]
    if IS_WINDOWS:
        for env in ('TEMP','TMP'):
            v=os.environ.get(env)
            if v: roots.append(Path(v))
    out=[]; seen=set()
    for root in roots:
        if not root.exists(): continue
        try:
            for e in root.iterdir():
                s=str(e)
                if s not in seen: seen.add(s); out.append(s)
        except Exception: pass
    return out


def clean_restore_message(raw: str) -> str:
    text = (raw or "").lower()
    if "access denied" in text or "unauthorized" in text:
        return "Restore point skipped: administrator permission required. Cleanup can continue with Backup Vault protection."
    if "disable" in text or "turned off" in text or "system protection" in text:
        return "Restore point skipped: Windows System Protection appears to be disabled."
    if raw and len(raw) < 160: return raw.strip()
    return "Restore point failed. Run as administrator and confirm System Protection is enabled."


def create_restore_point() -> tuple[bool, str]:
    if not IS_WINDOWS: return False, "Restore points are Windows-only."
    cmd=["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "Checkpoint-Computer -Description 'System Warden cleanup' -RestorePointType 'MODIFY_SETTINGS'"]
    try:
        p=subprocess.run(cmd, capture_output=True, text=True, timeout=90)
        if p.returncode == 0: return True, "Restore point created."
        return False, clean_restore_message(p.stderr or p.stdout)
    except Exception as exc:
        return False, clean_restore_message(str(exc))


def backup_paths(paths: list[str]) -> tuple[Path | None, str]:
    ensure_dirs(); stamp=datetime.now().strftime('%Y-%m-%d_%H-%M-%S')
    vault=VAULT_ROOT/stamp; (vault/'files').mkdir(parents=True, exist_ok=True)
    meta={"created": datetime.now().isoformat(timespec='seconds'), "items": []}
    ok=0
    for src in paths:
        p=Path(src)
        if not p.exists(): continue
        drive=(p.drive.replace(':','') if p.drive else 'root')
        parts=[x for x in p.parts if x not in (p.anchor, p.drive, '/', '\\')]
        dest=vault/'files'/drive/Path(*parts)
        try:
            dest.parent.mkdir(parents=True, exist_ok=True)
            if p.is_dir() and not p.is_symlink(): shutil.copytree(p, dest, dirs_exist_ok=True)
            else: shutil.copy2(p, dest)
            meta['items'].append({'source': str(p), 'backup': str(dest), 'size': path_size(p)}); ok += 1
        except Exception as exc:
            meta['items'].append({'source': str(p), 'error': str(exc), 'size': path_size(p)})
    (vault/'metadata.json').write_text(json.dumps(meta, indent=2), encoding='utf-8')
    return vault, f"Backup Vault saved {ok} item(s)."


def delete_path(path: str) -> tuple[bool, str]:
    p=Path(path)
    try:
        if p.is_dir() and not p.is_symlink(): shutil.rmtree(p)
        else: p.unlink()
        return True, f"Removed: {p}"
    except Exception as exc:
        return False, f"Failed: {p} — {exc}"


def restore_vault(vault: Path) -> tuple[int, int, list[str]]:
    try: meta=json.loads((vault/'metadata.json').read_text(encoding='utf-8'))
    except Exception: return 0,1,["metadata.json not found"]
    ok=fail=0; notes=[]
    for item in meta.get('items', []):
        src=Path(item.get('source','')); bak=Path(item.get('backup',''))
        if not bak.exists(): fail+=1; notes.append(f"Missing backup: {bak}"); continue
        if src.exists(): notes.append(f"Skipped existing: {src}"); continue
        try:
            src.parent.mkdir(parents=True, exist_ok=True)
            if bak.is_dir(): shutil.copytree(bak, src)
            else: shutil.copy2(bak, src)
            ok += 1
        except Exception as exc: fail += 1; notes.append(f"Failed {src}: {exc}")
    return ok, fail, notes

