        self.log_msg(f'Deep Search scanning for {q}...',GOLD)
        def work():
            paths=scan_associated_paths(q,True,int(self.deep_limit_var.get() or 3000)); self.after(0,lambda:self.render_queue(paths,f'Deep Search found {len(paths)} item(s).'))
        threading.Thread(target=work,daemon=True).start()

    def clean_selected(self):
        targets=[p for p,v,_s in self.queue if v.get() and Path(p).exists()]
        if not targets: messagebox.showinfo(APP_NAME,'No checked existing items to clean.'); return
        total=sum(path_size(p) for p in targets)
        if not messagebox.askyesno(APP_NAME,f'Clean {len(targets)} item(s)?\nEstimated size: {format_size(total)}\n\nBackup Vault: {"ON" if self.vault_var.get() else "OFF"}\nRestore Point: {"ON" if self.restore_var.get() else "OFF"}') : return
        self.btn_disable_notice=True; self.log_msg('Cleanup started...',GOLD)
        def work():
            rp_msg=''; rp_ok=False; vault=None; backup_msg=''
            if self.restore_var.get() and IS_WINDOWS:
                rp_ok,rp_msg=create_restore_point(); history({'action':'restore_point','status':'ok' if rp_ok else 'skipped','details':rp_msg})
            if self.vault_var.get():
                vault,backup_msg=backup_paths(targets); history({'action':'backup','status':'ok','vault':str(vault)})
            results=[]; ok=fail=0
            for t in targets:
                s,m=delete_path(t); ok+=int(s); fail+=int(not s); results.append((s,m))
            history({'action':'cleanup','status':'ok' if fail==0 else 'partial','removed':ok,'failed':fail,'vault':str(vault) if vault else ''})
            self.after(0,lambda:self.finish_cleanup(rp_ok,rp_msg,backup_msg,results,ok,fail))
        threading.Thread(target=work,daemon=True).start()
    def finish_cleanup(self,rp_ok,rp_msg,backup_msg,results,ok,fail):
        if rp_msg: self.log_msg(rp_msg, GREEN if rp_ok else ORANGE)
        if backup_msg: self.log_msg(backup_msg,GREEN)
        for s,m in results: self.log_msg(m, GREEN if s else RED)
        remain=[p for p,_,_ in self.queue if Path(p).exists()]
        self.render_queue(remain,f'Cleanup complete. Removed {ok}, failed {fail}.')
        if self.current_page=='Dashboard': self.show_dashboard()

