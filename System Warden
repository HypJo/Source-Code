        self.page_title(self.content,"Settings","Safety defaults and app folders.")
        f=self.card(self.content,fill="x")
        tk.Checkbutton(f,text="Create Windows restore point before cleanup",variable=self.create_restore_var,bg=PANEL,fg=TEXT,activebackground=PANEL,activeforeground=TEXT,selectcolor=BG,font=FONT_UI).pack(anchor="w",padx=14,pady=(14,6))
        tk.Checkbutton(f,text="Back up files to Backup Vault before deletion",variable=self.backup_vault_var,bg=PANEL,fg=TEXT,activebackground=PANEL,activeforeground=TEXT,selectcolor=BG,font=FONT_UI).pack(anchor="w",padx=14,pady=6)
        tk.Label(f,text=f"App data: {APP_DIR}\nVault: {VAULT_ROOT}",bg=PANEL,fg=TEXT_DIM,font=FONT_SMALL,justify="left").pack(anchor="w",padx=14,pady=(6,14))
        self.button(f,"Save Settings",self.save_settings,bg=GREEN,fg=BG).pack(anchor="w",padx=14,pady=(0,14))

    # Program logic
    def refresh_programs(self):
        self._log("Scanning installed programs...", GOLD)
        def work():
            progs=discover_programs()
            self.after(0,lambda:self.finish_refresh(progs))
        threading.Thread(target=work,daemon=True).start()

    def finish_refresh(self, progs):
        self.programs=progs
        self._log(f"Found {len(progs)} installed programs.", GREEN)
        if self.active_page=="Programs": self.populate_programs()
        if self.active_page=="Dashboard": self.show_dashboard()

    def populate_programs(self):
        if not hasattr(self,"listbox"): return
        flt=self.search_var.get().lower() if hasattr(self,"search_var") else ""
        self.filtered=[p for p in self.programs if flt in p.name.lower()]
        self.listbox.delete(0,"end")
        for p in self.filtered:
            self.listbox.insert("end", p.name + (f"  ({p.version})" if p.version else ""))
        self.count_label.configure(text=f"{len(self.filtered)} shown / {len(self.programs)} total")

    def selected_programs(self):
        if not hasattr(self,"listbox"): return []
        return [self.filtered[i] for i in self.listbox.curselection() if i < len(self.filtered)]

    def update_details(self):
        ps=self.selected_programs()
        if not ps:
            self.detail_text.configure(text="Select a program to view details."); return
        p=ps[0]
        self.detail_text.configure(text=f"Name: {p.name}\nVersion: {p.version or 'Unknown'}\nLocation: {p.location or 'Unknown'}\nSource: {p.source}\nUninstaller: {p.uninstall or 'Not listed'}")

    def scan_selected(self):
        ps=self.selected_programs()
        if not ps:
            messagebox.showinfo(APP_NAME,"Select a program first."); return
        p=ps[0]
        self._log(f"Scanning leftovers for {p.name}...", GOLD)
        def work():
            paths=scan_associated_paths(p, deep=False)
            self.after(0,lambda:self.render_queue(paths, f"Scan found {len(paths)} item(s)."))
        threading.Thread(target=work,daemon=True).start()

    def queue_selected_programs(self):
        ps=self.selected_programs()
        if not ps:
            messagebox.showinfo(APP_NAME,"Select one or more programs first."); return
        self._log(f"Queue scanning {len(ps)} program(s)...", GOLD)
        def work():
            paths=[]
            for p in ps: paths.extend(scan_associated_paths(p, deep=False))
            # unique
            seen=[]
            for x in paths:
                if x not in seen: seen.append(x)
            self.after(0,lambda:self.render_queue(seen, f"Queued {len(seen)} item(s)."))
        threading.Thread(target=work,daemon=True).start()

    def empty_queue(self, msg):
        if not hasattr(self,"items_frame"): return
        for w in self.items_frame.winfo_children(): w.destroy()
        self.scan_items=[]
        tk.Label(self.items_frame,text=msg,bg=BG_2,fg=TEXT_DIM,font=FONT_UI,justify="left").pack(anchor="w",padx=12,pady=12)
        if hasattr(self,"queue_label"): self.queue_label.configure(text="0 items")

    def render_queue(self, paths, msg=""):
        for w in self.items_frame.winfo_children(): w.destroy()
        self.scan_items=[]
        if not paths:
            self.empty_queue("No cleanup items found."); self._log("No items found.", ORANGE); return
        total=0
        for p in paths:
            sz=path_size(p); total+=sz; self.add_queue_row(p, sz)
        self.queue_label.configure(text=f"{len(paths)} items • {format_size(total)}")
        self._log(msg or f"Queued {len(paths)} item(s).", GREEN)

    def add_queue_row(self,path,sz=None):
        if sz is None: sz=path_size(path)
        var=tk.BooleanVar(value=True)
        row=tk.Frame(self.items_frame,bg=BG_2,highlightbackground=BORDER_DIM,highlightthickness=1)
        row.pack(fill="x",padx=8,pady=4)
        tk.Checkbutton(row,variable=var,bg=BG_2,activebackground=BG_2,selectcolor=BG).pack(side="left",padx=8)
        icon="Folder" if Path(path).is_dir() else "File"
        tk.Label(row,text=f"{icon}  {path}\n{format_size(sz)}",bg=BG_2,fg=TEXT,font=FONT_SMALL,justify="left",anchor="w").pack(side="left",fill="x",expand=True,pady=7)
        self.scan_items.append((path,var,sz))

    def toggle_all(self,state):
        for _p,v,_s in self.scan_items: v.set(state)

    def add_file(self):
        p=filedialog.askopenfilename(title="Add file to cleanup queue")
        if p: self.add_queue_row(p); self.queue_label.configure(text=f"{len(self.scan_items)} items")
    def add_folder(self):
        p=filedialog.askdirectory(title="Add folder to cleanup queue")
        if p: self.add_queue_row(p); self.queue_label.configure(text=f"{len(self.scan_items)} items")

    def clean_selected(self):
        targets=[p for p,v,_s in self.scan_items if v.get() and Path(p).exists()]
        if not targets:
            messagebox.showinfo(APP_NAME,"No checked existing items to clean."); return
        total=sum(path_size(p) for p in targets)
        if not messagebox.askyesno(APP_NAME, f"Clean {len(targets)} item(s)?\nEstimated size: {format_size(total)}\n\nBackup Vault: {'ON' if self.backup_vault_var.get() else 'OFF'}\nRestore Point: {'ON' if self.create_restore_var.get() else 'OFF'}"):
            return
        if self.create_restore_var.get() and IS_WINDOWS:
            ok,msg=create_restore_point("System Warden cleanup")
            self._log(msg, GREEN if ok else ORANGE)
            append_history({"action":"restore_point","status":"ok" if ok else "failed","details":msg})
        vault=None
        if self.backup_vault_var.get():
            vault,msg=backup_paths(targets); self._log(msg,GREEN); append_history({"action":"backup","status":"ok","vault":str(vault)})
        ok=fail=0
        for p in targets:
            success,msg=delete_path(p); ok+=int(success); fail+=int(not success); self._log(msg, GREEN if success else RED)
        append_history({"action":"cleanup","status":"ok" if fail==0 else "partial","removed":ok,"failed":fail,"vault":str(vault) if vault else ""})
        self.render_queue([p for p,_,_ in self.scan_items if Path(p).exists()], f"Cleanup complete. Removed {ok}, failed {fail}.")

    def scan_temp_junk(self):
        if self.active_page not in ("Hunter","Programs"):
            self.show_hunter()
        self._log("Temp Hunter scanning...", GOLD)
        def work():
            paths=get_temp_items()
            self.after(0,lambda:self.render_queue(paths, f"Temp Hunter found {len(paths)} item(s)."))
        threading.Thread(target=work,daemon=True).start()

    def deep_hunter_from_page(self):
        q=self.hunter_query.get().strip()
        if not q:
            messagebox.showinfo(APP_NAME,"Type an app or folder name to deep search."); return
        self.deep_hunter(q)

    def deep_hunter(self, query: str):
        fake=Program(query)
        self._log(f"Deep Hunter scanning for {query}...", GOLD)
        def work():
            paths=scan_associated_paths(fake,deep=True,limit=int(self.settings.get("deep_scan_limit",1500)))
            self.after(0,lambda:self.render_queue(paths, f"Deep Hunter found {len(paths)} item(s)."))
        threading.Thread(target=work,daemon=True).start()

    def run_official(self):
        ps=self.selected_programs()
        if not ps: messagebox.showinfo(APP_NAME,"Select a program first."); return
        cmd=ps[0].uninstall
        if not cmd: messagebox.showinfo(APP_NAME,"No official uninstaller is listed for this app."); return
        if not messagebox.askyesno(APP_NAME,f"Run official uninstaller?\n\n{cmd}"): return
        try:
            subprocess.Popen(cmd, shell=True)
            append_history({"action":"official_uninstaller","status":"launched","program":ps[0].name})
            self._log("Official uninstaller launched.", GREEN)
        except Exception as exc:
            messagebox.showerror(APP_NAME,str(exc)); self._log(str(exc),RED)

    # Vault/history helpers
    def get_vaults(self):
        ensure_dirs(); return sorted([p for p in VAULT_ROOT.iterdir() if p.is_dir()], reverse=True)
    def read_vault_meta(self,v):
        try: return json.loads((v/"metadata.json").read_text(encoding="utf-8"))
        except Exception: return {"items":[]}
    def open_vault(self):
        ensure_dirs()
        try:
            os.startfile(str(VAULT_ROOT)) if IS_WINDOWS else subprocess.Popen(["open" if IS_MAC else "xdg-open", str(VAULT_ROOT)])
        except Exception as exc: messagebox.showerror(APP_NAME,str(exc))
    def restore_latest(self):
        vaults=self.get_vaults()
        if not vaults: messagebox.showinfo(APP_NAME,"No vault backups found."); return
        self.restore_vault_path(vaults[0])
    def restore_selected_vault(self):
        sel=self.vault_tree.selection() if hasattr(self,"vault_tree") else []
        if not sel: messagebox.showinfo(APP_NAME,"Select a vault first."); return
        vals=self.vault_tree.item(sel[0],"values"); self.restore_vault_path(Path(vals[3]))
    def restore_vault_path(self,vault):
        if not messagebox.askyesno(APP_NAME,f"Restore missing files from this vault?\nExisting files will not be overwritten.\n\n{vault}"): return
        ok,fail,notes=restore_vault(Path(vault))
        append_history({"action":"restore_vault","status":"ok" if fail==0 else "partial","vault":str(vault),"restored":ok,"failed":fail})
        self._log(f"Vault restore complete: {ok} restored, {fail} failed/skipped.", GREEN if fail==0 else ORANGE)
        if notes: messagebox.showinfo(APP_NAME,"\n".join(notes[:20]))
    def export_report(self):
        p=filedialog.asksaveasfilename(title="Export report", defaultextension=".txt", filetypes=[("Text","*.txt")])
        if not p: return
        lines=[f"{APP_NAME} Report",f"Generated: {datetime.now().isoformat(timespec='seconds')}",f"App dir: {APP_DIR}",f"Vault: {VAULT_ROOT}","","History:"]
        for e in read_history(500): lines.append(json.dumps(e,ensure_ascii=False))
        Path(p).write_text("\n".join(lines),encoding="utf-8")
        append_history({"action":"export_report","status":"ok","path":p})
        self._log(f"Report exported: {p}",GREEN)
    def save_settings(self):
        self.settings.update({"create_restore_point":self.create_restore_var.get(),"backup_vault":self.backup_vault_var.get()})
        save_settings(self.settings); self._log("Settings saved.",GREEN); self.show_dashboard()
    def show_safety(self):
        messagebox.showinfo(APP_NAME,"Safety Notes\n\n• Keep Backup Vault enabled.\n• Restore point creation may require admin rights and System Protection enabled.\n• Deep Hunter can show false positives. Review every path before cleaning.\n• This app does not permanently delete backups unless you remove the vault folder.")


